# === Prepped backend environment ===
# Copia este archivo a `.env` y rellena los valores. `.env` NO se versiona.

# OpenAI (único punto del sistema que llama a un LLM: extracción + verbalización)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Base de datos (prototipo: SQLite; misma forma de schema que el Postgres north-star)
DATABASE_URL=sqlite:///./prepped.db

# CORS: orígenes permitidos del frontend (separados por coma)
CORS_ORIGINS=http://localhost:5173
